{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist/types",
    "noEmit": false,
    "declaration": true,
    "declarationMap": true,

    /* Build compatibility */
    "allowImportingTsExtensions": false,
    "emitDeclarationOnly": true
  },
  "include": ["src"]
}